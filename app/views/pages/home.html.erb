<% content_for :title, "Talk to the Hand" %>

<div class="max-w-3xl mx-auto">
  <h1 class="text-4xl font-semibold tracking-tight text-neutral-100">Talk to the Hand 🤚</h1>
  <p class="mt-4 text-neutral-400 leading-relaxed">
    Practice the indoor skydiving hand code for windspeeds 1-99. Numbers are shown
    with the <strong class="text-neutral-200 font-medium">back of the hand</strong>: a <em class="not-italic text-neutral-200">tens</em> gesture, then a
    <em class="not-italic text-neutral-200">ones</em> gesture.
  </p>

  <div class="mt-10 grid gap-4 sm:grid-cols-2">
    <%= link_to show_mode_path, class: "group block rounded-2xl border border-white/10 bg-neutral-900/40 p-6 transition hover:border-sky-400/40 hover:bg-neutral-900/70" do %>
      <div class="text-2xl">🤚 → 📷</div>
      <h2 class="mt-4 text-xl font-medium text-neutral-100">Show mode</h2>
      <p class="mt-1 text-sm text-neutral-400">
        The app gives you a number. Sign it to your camera and it checks your gesture.
      </p>
      <span class="mt-4 inline-block text-sm text-sky-400 opacity-0 transition group-hover:opacity-100">Start training →</span>
    <% end %>

    <%= link_to recognize_mode_path, class: "group block rounded-2xl border border-white/10 bg-neutral-900/40 p-6 transition hover:border-sky-400/40 hover:bg-neutral-900/70" do %>
      <div class="text-2xl">👀 → ⌨️</div>
      <h2 class="mt-4 text-xl font-medium text-neutral-100">Recognize mode</h2>
      <p class="mt-1 text-sm text-neutral-400">
        The app shows a gesture. Read it and type the number it represents.
      </p>
      <span class="mt-4 inline-block text-sm text-sky-400 opacity-0 transition group-hover:opacity-100">Start training →</span>
    <% end %>
  </div>

  <% skin_swatches = [
       ["#ffe0bd", "#d9a06b"],
       ["#f5cfa0", "#c98f5e"],
       ["#e6b48c", "#b07a52"],
       ["#d99a6c", "#a86a3c"],
       ["#c5824e", "#94552c"],
       ["#a96a3c", "#7c4421"],
       ["#8a5524", "#623414"],
       ["#5c3a1e", "#3d2410"],
     ]
     fun_swatches = [
       ["#f5f5f5", "#9ca3af"],
       ["#f5d042", "#c2a012"],
       ["#f7951d", "#b86a0e"],
       ["#3fbf6f", "#268a4c"],
       ["#9b6cf7", "#6b41b0"],
       ["#4f8ef7", "#2c5fb0"],
       ["#e9573f", "#b3301c"],
       ["#111111", "#6b7280"],
     ] %>

  <section class="mt-4 rounded-2xl border border-white/10 bg-neutral-900/40 p-6">
    <div class="flex items-center gap-5">
      <div class="shrink-0 rounded-xl border border-white/10 bg-neutral-950/40 p-2">
        <%= hand_sign_svg({ place: :preview, fingers: 4, orientation: :up, thumb: false }, size: 72) %>
      </div>
      <div class="flex-1">
        <h2 class="text-sm font-medium text-neutral-200">Hand colour</h2>
        <p class="mt-1 text-xs text-neutral-500">Pick a colour for the gesture hands. It’s remembered on this device.</p>
        <div class="mt-3 space-y-6 rounded-2xl bg-neutral-950/40 p-2">
          <div class="flex flex-wrap items-center gap-2">
            <% skin_swatches.each_with_index do |(fill, stroke), i| %>
              <button type="button"
                      data-hand-color-target="swatch"
                      data-action="hand-color#choose"
                      data-fill="<%= fill %>"
                      data-stroke="<%= stroke %>"
                      <%= 'data-default="true"'.html_safe if fill == "#e6b48c" %>
                      aria-label="Skin tone <%= i + 1 %>"
                      aria-pressed="false"
                      class="h-8 w-8 shrink-0 rounded-full border border-black/20 shadow-sm transition hover:scale-110"
                      style="background-color: <%= fill %>"></button>
            <% end %>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <% fun_swatches.each_with_index do |(fill, stroke), i| %>
              <button type="button"
                      data-hand-color-target="swatch"
                      data-action="hand-color#choose"
                      data-fill="<%= fill %>"
                      data-stroke="<%= stroke %>"
                      aria-label="Hand colour <%= i + 1 %>"
                      aria-pressed="false"
                      class="h-8 w-8 shrink-0 rounded-full border shadow-sm transition hover:scale-110 <%= fill == "#111111" ? "border-neutral-800" : "border-black/20" %>"
                      style="background-color: <%= fill %>"></button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <p class="mt-8 text-sm text-neutral-500">
    New to the code? <%= link_to "Learn the hand gestures", help_path, class: "text-sky-400 hover:text-sky-300" %>.
  </p>
</div>
