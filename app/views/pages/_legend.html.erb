<div class="mt-12">
  <h2 class="text-lg font-medium text-neutral-100">The gesture code</h2>
  <p class="mt-1 text-sm text-neutral-500">Shown with the back of the hand. Thumb is not used for counting except for 5.</p>

  <div class="mt-6 grid gap-10 md:grid-cols-2">
    <div>
      <h3 class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Tens</h3>
      <div class="mt-4 grid grid-cols-3 gap-3">
        <% [10, 20, 30, 40, 50, 60, 70, 80, 90].each do |n| %>
          <%= render "pages/sign_tile", value: n, gesture: tens_gesture(n / 10) %>
        <% end %>
      </div>
      <p class="mt-3 text-xs text-neutral-500">10-40: fingers down · 50: fist · 60-90: fingers sideways</p>
    </div>

    <div>
      <h3 class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Ones</h3>
      <div class="mt-4 grid grid-cols-3 gap-3">
        <% (1..9).each do |n| %>
          <%= render "pages/sign_tile", value: n, gesture: ones_gesture(n) %>
        <% end %>
      </div>
      <p class="mt-3 text-xs text-neutral-500">1-4: fingers down · 5: thumb up · 6-9: fingers up</p>
    </div>
  </div>

  <div class="mt-10">
    <h3 class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Combined (×5)</h3>
    <p class="mt-1 text-xs text-neutral-500">55, 65, 75, 85, 95 are one gesture: fingers sideways with the thumb up.</p>
    <div class="mt-4 grid grid-cols-5 gap-3 max-w-md">
      <% [55, 65, 75, 85, 95].each do |n| %>
        <%= render "pages/sign_tile", value: n, gesture: combined_gesture(n) %>
      <% end %>
    </div>
  </div>
</div>
