<% content_for :title, "Show mode" %>

<div class="max-w-3xl mx-auto" data-controller="show-game">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-neutral-100">Show mode</h1>
      <p class="mt-1 text-neutral-400">Sign the number with the back of your hand. Hold each gesture steady to capture it.</p>
    </div>
    <div class="flex gap-2">
      <button data-action="show-game#start" data-show-game-target="startButton"
              class="rounded-xl bg-sky-500 px-4 py-2 text-sm font-medium text-neutral-950 transition hover:bg-sky-400">Start</button>
      <button data-action="show-game#stop" data-show-game-target="stopButton"
              class="hidden rounded-xl border border-white/10 bg-neutral-900/50 px-4 py-2 text-sm font-medium text-neutral-300 transition hover:bg-neutral-800">Stop</button>
    </div>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-3">
    <div class="rounded-2xl border border-white/10 bg-neutral-900/40 p-6 md:col-span-1">
      <div data-show-game-target="prompt" class="mt-2 text-2xl font-medium text-neutral-500">Press Start</div>
      <div data-show-game-target="step" class="mt-3 text-neutral-400"></div>
      <div data-show-game-target="captured" class="mt-1 text-sm text-neutral-500"></div>
      <div data-show-game-target="feedback" class="mt-5 text-lg font-medium min-h-7"></div>
      <div data-show-game-target="solution" class="mt-3 text-sm text-neutral-400 hidden"></div>
      <div class="mt-4 flex gap-3">
        <button data-action="show-game#showSolution" data-show-game-target="solutionButton"
                class="hidden text-xs text-neutral-600 underline underline-offset-2 hover:text-neutral-400 transition-colors">Show solution</button>
        <button data-action="show-game#skip" data-show-game-target="skipButton"
                class="hidden text-xs text-neutral-600 underline underline-offset-2 hover:text-neutral-400 transition-colors">Skip</button>
      </div>
    </div>

    <div class="rounded-2xl border border-white/10 bg-neutral-900/40 p-6 md:col-span-2">
        <video data-show-game-target="video" class="h-full w-full object-cover -scale-x-100" playsinline muted></video>
      </div>
      <div class="mt-4 flex items-center justify-between text-sm">
        <span class="text-neutral-500">Reading: <span data-show-game-target="live" class="font-medium text-neutral-200">—</span></span>
        <span data-show-game-target="status" class="text-neutral-500"></span>
      </div>
    </div>
  </div>

  <p class="mt-5 text-xs text-neutral-600">
    Camera access is required and runs entirely in your browser. Use Start/Stop to control the session.
  </p>

  <p class="mt-3 text-sm text-neutral-500">
    Need a refresher? <%= link_to "View the gesture guide", help_path, class: "text-sky-400 hover:text-sky-300" %>.
  </p>
</div>
