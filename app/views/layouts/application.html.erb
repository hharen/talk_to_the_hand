<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Talk to the Hand" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Talk to the Hand">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#0a0a0a">

    <script>
      (function () {
        try {
          var s = JSON.parse(localStorage.getItem("handSkin"))
          if (s && s.fill) {
            var root = document.documentElement.style
            root.setProperty("--hand-skin", s.fill)
            root.setProperty("--hand-skin-stroke", s.stroke)
          }
        } catch (e) {}
      })()
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="hand-color" class="relative min-h-screen bg-neutral-950 text-neutral-300 antialiased selection:bg-sky-500/30">
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(60rem_40rem_at_50%_-10%,rgba(56,189,248,0.10),transparent)]"></div>
    <header class="sticky top-0 z-20 border-b border-white/5 bg-neutral-950/70 backdrop-blur">
      <div class="container mx-auto px-5 py-4 flex items-center justify-between">
        <%= link_to root_path, class: "font-semibold text-lg tracking-tight text-neutral-100" do %>
          Talk to the Hand 🤚
        <% end %>
        <nav class="flex gap-6 text-sm text-neutral-400">
          <%= link_to "Show", show_mode_path, class: "hover:text-neutral-100 transition-colors" %>
          <%= link_to "Recognize", recognize_mode_path, class: "hover:text-neutral-100 transition-colors" %>
          <%= link_to "Help", help_path, class: "hover:text-neutral-100 transition-colors" %>
        </nav>
      </div>
    </header>
    <main class="container mx-auto mt-12 mb-24 px-5">
      <%= yield %>
    </main>
    <footer class="border-t border-white/5 py-6 text-center text-sm text-neutral-500">
      Made with 💜 and <%= link_to "Copilot", "https://github.com/copilot", target: "_blank", rel: "noopener noreferrer", class: "text-sky-600 underline underline-offset-2 hover:text-sky-500 transition-colors" %> by <%= link_to "hharen", "https://hharen.com", target: "_blank", rel: "noopener noreferrer", class: "text-sky-600 underline underline-offset-2 hover:text-sky-500 transition-colors" %>
    </footer>
  </body>
</html>\
